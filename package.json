		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/bcrypt": "^6.0.0",
		"@types/node": "^24",
		"@vercel/analytics": "^2.0.1",
		"@vercel/speed-insights": "^2.0.0",
		"@vitest/browser-playwright": "^4.1.8",
		"autoprefixer": "^10.5.2",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
